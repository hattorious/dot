{
  "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
  "name": "Solarized Dark",
  "author": "Ethan Schoonover",
  "themes": [
    {
      "name": "Solarized Dark",
      "appearance": "dark",
      "style": {
        "background": "#002b36",
        "foreground": "#839496",
        "border": "#073642",
        "border.variant": "#073642",
        "border.focused": "#268bd2",
        "border.selected": "#268bd2",
        "border.transparent": "#00000000",
        "border.disabled": "#073642",

        "elevated_surface.background": "#073642",
        "surface.background": "#073642",
        "panel.background": "#002b36",
        "panel.focused_border": "#268bd2",
        "pane.focused_border": "#268bd2",

        "status_bar.background": "#073642",
        "title_bar.background": "#002b36",
        "title_bar.inactive_background": "#002b36",
        "toolbar.background": "#002b36",
        "tab_bar.background": "#002b36",
        "tab.inactive_background": "#002b36",
        "tab.active_background": "#073642",

        "editor.background": "#002b36",
        "editor.foreground": "#839496",
        "editor.gutter.background": "#002b36",
        "editor.subheader.background": "#073642",
        "editor.active_line.background": "#073642",
        "editor.highlighted_line.background": "#073642",
        "editor.line_number": "#586e75",
        "editor.active_line_number": "#839496",
        "editor.invisible": "#586e75",
        "editor.wrap_guide": "#073642",
        "editor.active_wrap_guide": "#586e75",
        "editor.indent_guide": "#073642",
        "editor.indent_guide_active": "#586e75",
        "editor.document_highlight.read_background": "#073642",
        "editor.document_highlight.write_background": "#586e7540",

        "search.match_background": "#b5890040",

        "scrollbar.thumb.background": "#586e7560",
        "scrollbar.thumb.hover_background": "#586e75",
        "scrollbar.track.background": "#002b36",
        "scrollbar.track.border": "#073642",

        "drop_target.background": "#26537260",

        "ghost_element.background": "#00000000",
        "ghost_element.hover": "#07364280",
        "ghost_element.active": "#073642",
        "ghost_element.selected": "#073642",
        "ghost_element.disabled": "#073642",

        "element.background": "#073642",
        "element.hover": "#0a4454",
        "element.active": "#0d5266",
        "element.selected": "#073642",
        "element.disabled": "#002b36",

        "text": "#839496",
        "text.muted": "#586e75",
        "text.placeholder": "#586e75",
        "text.disabled": "#586e75",
        "text.accent": "#268bd2",

        "icon": "#839496",
        "icon.muted": "#586e75",
        "icon.disabled": "#586e75",
        "icon.placeholder": "#586e75",
        "icon.accent": "#268bd2",

        "link_text.hover": "#268bd2",

        "players": [
          { "cursor": "#268bd2", "background": "#268bd220", "selection": "#268bd230" },
          { "cursor": "#2aa198", "background": "#2aa19820", "selection": "#2aa19830" },
          { "cursor": "#859900", "background": "#85990020", "selection": "#85990030" },
          { "cursor": "#d33682", "background": "#d3368220", "selection": "#d3368230" },
          { "cursor": "#b58900", "background": "#b5890020", "selection": "#b5890030" },
          { "cursor": "#6c71c4", "background": "#6c71c420", "selection": "#6c71c430" },
          { "cursor": "#cb4b16", "background": "#cb4b1620", "selection": "#cb4b1630" },
          { "cursor": "#dc322f", "background": "#dc322f20", "selection": "#dc322f30" }
        ],

        "terminal.background": "#002b36",
        "terminal.foreground": "#839496",
        "terminal.bright_foreground": "#93a1a1",
        "terminal.dim_foreground": "#586e75",
        "terminal.ansi.black": "#002b36",
        "terminal.ansi.bright_black": "#657b83",
        "terminal.ansi.red": "#dc322f",
        "terminal.ansi.bright_red": "#dc322f",
        "terminal.ansi.green": "#859900",
        "terminal.ansi.bright_green": "#859900",
        "terminal.ansi.yellow": "#b58900",
        "terminal.ansi.bright_yellow": "#b58900",
        "terminal.ansi.blue": "#268bd2",
        "terminal.ansi.bright_blue": "#268bd2",
        "terminal.ansi.magenta": "#d33682",
        "terminal.ansi.bright_magenta": "#6c71c4",
        "terminal.ansi.cyan": "#2aa198",
        "terminal.ansi.bright_cyan": "#2aa198",
        "terminal.ansi.white": "#839496",
        "terminal.ansi.bright_white": "#fdf6e3",

        "conflict": "#b58900",
        "conflict.background": "#b5890020",
        "conflict.border": "#b58900",
        "created": "#859900",
        "created.background": "#85990020",
        "created.border": "#859900",
        "deleted": "#dc322f",
        "deleted.background": "#dc322f20",
        "deleted.border": "#dc322f",
        "error": "#dc322f",
        "error.background": "#dc322f20",
        "error.border": "#dc322f",
        "hidden": "#586e75",
        "hidden.background": "#002b36",
        "hidden.border": "#586e75",
        "hint": "#586e75",
        "hint.background": "#073642",
        "hint.border": "#586e75",
        "ignored": "#586e75",
        "ignored.background": "#002b36",
        "ignored.border": "#586e75",
        "info": "#268bd2",
        "info.background": "#268bd220",
        "info.border": "#268bd2",
        "modified": "#b58900",
        "modified.background": "#b5890020",
        "modified.border": "#b58900",
        "renamed": "#268bd2",
        "renamed.background": "#268bd220",
        "renamed.border": "#268bd2",
        "success": "#859900",
        "success.background": "#85990020",
        "success.border": "#859900",
        "warning": "#b58900",
        "warning.background": "#b5890020",
        "warning.border": "#b58900",
        "unreachable": "#586e75",
        "unreachable.background": "#002b36",
        "unreachable.border": "#586e75",

        "syntax": {
          "attribute":          { "color": "#2aa198" },
          "boolean":            { "color": "#268bd2" },
          "comment":            { "color": "#586e75", "font_style": "italic" },
          "comment.doc":        { "color": "#586e75", "font_style": "italic" },
          "constant":           { "color": "#268bd2" },
          "constructor":        { "color": "#268bd2" },
          "embedded":           { "color": "#839496" },
          "emphasis":           { "color": "#839496", "font_style": "italic" },
          "emphasis.strong":    { "color": "#839496", "font_weight": 700 },
          "enum":               { "color": "#b58900" },
          "function":           { "color": "#268bd2" },
          "function.builtin":   { "color": "#2aa198" },
          "function.definition":{ "color": "#268bd2" },
          "keyword":            { "color": "#859900" },
          "label":              { "color": "#2aa198" },
          "link_text":          { "color": "#268bd2" },
          "link_uri":           { "color": "#2aa198" },
          "number":             { "color": "#2aa198" },
          "operator":           { "color": "#839496" },
          "preproc":            { "color": "#cb4b16" },
          "property":           { "color": "#268bd2" },
          "punctuation":        { "color": "#839496" },
          "punctuation.bracket":{ "color": "#839496" },
          "punctuation.delimiter": { "color": "#839496" },
          "punctuation.list_marker": { "color": "#2aa198" },
          "punctuation.special":{ "color": "#dc322f" },
          "string":             { "color": "#2aa198" },
          "string.escape":      { "color": "#dc322f" },
          "string.regex":       { "color": "#dc322f" },
          "string.special":     { "color": "#cb4b16" },
          "string.special.symbol": { "color": "#2aa198" },
          "tag":                { "color": "#268bd2" },
          "text.literal":       { "color": "#2aa198" },
          "title":              { "color": "#b58900", "font_weight": 700 },
          "type":               { "color": "#b58900" },
          "variable":           { "color": "#839496" },
          "variable.member":    { "color": "#268bd2" },
          "variable.parameter": { "color": "#cb4b16" }
        }
      }
    }
  ]
}
