[core]
	editor = vim
	excludesfile = ~/.gitignore_global
	whitespace = trailing-space,space-before-tab
	pager = delta

[pager]
	log = delta
	reflog = delta
	show = delta

[delta]
	navigate = true
	syntax-theme = rose-pine

[interactive]
	diffFilter = delta --color-only

[alias]
	co = checkout
	cm = commit
	st = status
	cl = clone
	hist = log --graph --oneline --no-merges
	ll = log --pretty=format:"%C(yellow)%h%Cred%d\\ %Creset%s%Cblue\\ [%cn]" --decorate --numstat
	fl = log -u
	dl = "!git ll -1"
	dlc = diff --cached HEAD^
	dr  = "!f() { git diff "$1"^.."$1"; }; f"
	lc  = "!f() { git ll "$1"^.."$1"; }; f"
	diffr  = "!f() { git diff "$1"^.."$1"; }; f"
	la = "!git config -l | grep alias | cut -c 7-"
	ours = "!f() { git co --ours $@ && git add $@; }; f"
	theirs = "!f() { git co --theirs $@ && git add $@; }; f"
	type = cat-file -t
	dump = cat-file -p
	g = grep --break --heading --line-number
	code-changes = "!git log --format=format: --name-only | egrep -v '^$' | sort | uniq -c | sort -rg | grep -v package | head -10"
	po = "!git push origin $(git rev-parse --abbrev-ref HEAD)"
	ph = "!git push github $(git rev-parse --abbrev-ref HEAD)"
	up = pull --rebase --autostash --all
	cb = "!git rev-parse --abbrev-ref HEAD"
	envar = "!echo \"$REVIEW_BASE\""
	files = "!git diff --name-only $(git merge-base HEAD \"$REVIEW_BASE\")"
	stat = "!git diff --stat $(git merge-base HEAD \"$REVIEW_BASE\")"
	tree = log --graph --pretty=oneline --abbrev-commit --decorate --color
	cp = cherry-pick -x
	b = branch -v
	br = for-each-ref --sort=committerdate refs/heads/ --format='%(HEAD) %(color:yellow)%(refname:short)%(color:reset) - %(color:red)%(objectname:short)%(color:reset) - %(contents:subject) - %(authorname) (%(color:green)%(committerdate:relative)%(color:reset))'
	r = remote -v
	t = tag -l
	unstage = reset HEAD
	uncommit = reset --soft HEAD^
	copr = !sh -c 'git fetch origin pull/$1/head:pr/$1 && git checkout pr/$1' -

[diff]
	renames = copies

[merge]
	summary = true
	stat = true
	tool = diffconflicts

[mergetool]
	keepBackup = false

[mergetool "diffconflicts"]
	cmd = vim -c DiffConflicts "$MERGED" "$BASE" "$LOCAL" "$REMOTE"
	trustExitCode = true

[init]
	defaultBranch = main
 
[branch]
	autosetuprebase = always

[color]
	diff = auto
	status = auto
	branch = auto
	interactive = auto
	ui = auto

[commit]
	template = ~/.gitcommittemplate
	;gpgsign = true

[gc]
	auto = 1

[rerere]
	enabled = true

[push]
	default = current

[pull]
	ff = only

# Allow local customizations in the .gitconfig.local file
[include]
	path = ~/.gitconfig.local
